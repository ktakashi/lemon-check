{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "{{", "close": "}}" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "{{", "close": "}}" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(scenario|outline|feature|background|fragment|given|when|then|and|but|parameters|examples):.*$",
    "decreaseIndentPattern": "^\\s*(scenario|outline|feature|fragment|examples):.*$"
  },
  "wordPattern": "[\\w\\-\\$\\.\\^@]+"
}
