# External Body File Test
# Demonstrates loading request body from external files with variable interpolation
# Requires variable sharing to pass {{otherName}} from first scenario to outline examples

parameters:
  shareVariablesAcrossScenarios: true

scenario: Create pet using external body file
  given I have a pet name to use
    # This step sets up the petName variable that the body template will use
    call ^listPets
    extract $.pets[0].name => otherName

outline: Create pet with parameterized name
  when I create a pet using a template file
    call ^createPet
      bodyFile: "classpath:templates/create-pet-template.json"
    extract $.id => createdPetId
    assert status 201
    assert $.status equals "available"
    assert $.category equals "test"
    assert $.name equals "{{petName}}"
    assert $.name matches "^{{petName}}$"
    assert contains "{{petName}}"

  but body does not contain literal variable placeholder
    # Using \\{{ to escape and check for literal {{petName}} in response (double backslash in source)
    assert not contains "\\{{petName}}"

  then I verify the pet was created correctly
    call ^getPetById
      petId: {{createdPetId}}
    assert status 200
    assert $.category equals "test"

  and clean up the pet
    call ^deletePet
      petId: {{createdPetId}}
    assert status 204

  examples:
    | petName       |
    | {{otherName}} |
    | Max           |