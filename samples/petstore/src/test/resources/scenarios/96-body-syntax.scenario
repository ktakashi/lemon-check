# Test scenario for body syntax
# Demonstrates:
# - body: with inline JSON (raw JSON)
# - body: with structured properties (schema defaults merged)
# - body: with triple-quoted multi-line JSON

scenario: Create pet with raw body
  when I create a pet with raw JSON
    call ^createPet
      body: {"name": "RawPet", "status": "available", "category": "dog"}
  then pet is created
    assert status 201
    assert $.name equals "RawPet"

scenario: Create pet with structured body
  when I create a pet with structured properties
    call ^createPet
      body:
        name: StructuredPet
        status: available
        category: cat
  then pet is created
    assert status 201
    assert $.name equals "StructuredPet"

scenario: Create pet with partial body
  # Only specify name, other fields (status, category) use schema defaults
  when I create a pet with minimal data
    call ^createPet
      body:
        name: PartialPet
  then pet is created with defaults
    assert status 201
    assert $.name equals "PartialPet"

scenario: Create pet with nested body
  # Test nested object in body
  when I create a pet with nested tags
    call ^createPet
      body:
        name: NestedPet
        status: available
  then pet is created
    assert status 201
    assert $.name equals "NestedPet"

scenario: Create pet with multi-line body
  # Test triple-quoted multi-line body
  when I create a pet with multi-line JSON
    call ^createPet
      body:
        """
        {
          "name": "MultiLinePet",
          "status": "available",
          "category": "bird"
        }
        """
  then pet is created
    assert status 201
    assert $.name equals "MultiLinePet"
    assert $.category equals "bird"
