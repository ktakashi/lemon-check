# Test scenario file demonstrating file-level parameters
# The parameters section can override configuration settings

parameters:
  shareVariablesAcrossScenarios: true
  logRequests: false
  timeout: 60

# Scenario 1: Create a pet and extract its ID
scenario: Create pet for variable sharing test
  when I create a pet
    call ^createPet
      body: {"name": "ParametersTestPet", "status": "available", "category": "test", "price": 150.00}
  then the pet is created
    assert status 201
    assert $.name equals "ParametersTestPet"
    extract $.id => parametersPetId

# Scenario 2: Use the extracted ID (proves variable sharing via parameters works)
scenario: Verify pet using shared variable
  when I retrieve the pet
    call ^getPetById
      petId: {{parametersPetId}}
  then I see the correct pet
    assert status 200
    assert $.name equals "ParametersTestPet"

# Scenario 3: Clean up
scenario: Delete the test pet
  when I delete the pet
    call ^deletePet
      petId: {{parametersPetId}}
  then deletion succeeds
    assert status 204
