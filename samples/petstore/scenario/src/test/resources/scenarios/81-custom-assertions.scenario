# Custom Assertion Demonstration
# This scenario file demonstrates BerryCrush's custom assertion capability
# with user-defined assertion implementations from PetstoreAssertions.

scenario: Custom assertions with API response
  when I create a test pet
    call ^createPet
      body: {"name": "AssertionTestPet", "status": "available"}
  then verify pet status using custom assertion
    assert the pet should have status "available"

scenario: Custom assertion for pet name
  when I create a pet for name assertion
    call ^createPet
      body: {"name": "CustomAssertPet", "status": "pending"}
  then verify pet details using custom assertions
    assert the pet name should be "CustomAssertPet"
    assert the pet should have status "pending"
